# App
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/emsc_academy?schema=public

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-256-bits
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=another-secret-for-refresh-tokens
REFRESH_TOKEN_EXPIRES_IN=30d

# Redis (optional - for caching/queues)
REDIS_URL=redis://localhost:6379
# Or individual: REDIS_HOST, REDIS_PORT, REDIS_PASSWORD

# Stripe (if using payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (choose one provider)
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...
# SENDGRID_API_KEY=...
# MAILGUN_API_KEY=...
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
FROM_EMAIL=noreply@emsc.academy
FROM_NAME=EMSC Academy

# CORS
CORS_ORIGIN=https://emsc-academy.vercel.app,https://academy.emsc.es,http://localhost:3000

# Monitoring
SENTRY_DSN=https://...
LOG_LEVEL=info

# Features
FEATURE_VIDEO_NOTES=true
FEATURE_CERTIFICATES=true
FEATURE_COMMUNITY=true
FEATURE_AFFILIATES=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_REQUESTS_STRICT=10

# File Uploads
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_TYPES=pdf,doc,docx,zip,mp4

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Cache TTL (seconds)
CACHE_TTL_PUBLIC=1800
CACHE_TTL_COURSES=3600